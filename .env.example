# bedrock-claude-contract-suite — environment template
#
# Copy this file to `.env` and fill in real values. `.env` is gitignored.
# Never commit real tokens. The `secret-scan.sh` hook will block commits
# containing the ABSK... pattern.

# REQUIRED — Amazon Bedrock API key (Bearer token).
# Issue from the Bedrock console under "API keys".
# Format: base64-like string starting with "ABSK".
AWS_BEARER_TOKEN_BEDROCK=ABSK...replace-me

# Optional — region for the Bedrock endpoint. Default: ap-northeast-2.
# Other tested regions: us-east-1, us-west-2.
AWS_REGION=ap-northeast-2

# Optional — single-model run target. Default:
#   global.anthropic.claude-opus-4-7
# Matrix mode (--all-models) ignores this and iterates `config.ALL_MODELS`.
BEDROCK_MODEL_ID=global.anthropic.claude-opus-4-7

# Optional — webhook URL for the notify.sh hook.
# Set to a Slack/Discord/etc. incoming webhook to receive Claude Code
# event notifications. Leave empty to disable.
CLAUDE_NOTIFY_WEBHOOK=

# ── Claude Platform on AWS ─────────────────────────────────────────────
# Required to run --providers cpaws. Issued from the AWS Console under
# Claude Platform on AWS → API keys. The workspace ID is shown on the
# Workspaces page. Both must belong to the AWS-connected Anthropic org.
# Format of API key: base64-like string starting with "AEAA"
# (NOT "sk-ant-" — that prefix is for direct Anthropic API keys, not CPaws).
# Endpoint is auto-derived from CPAWS_REGION:
#   https://aws-external-anthropic.{region}.api.aws
ANTHROPIC_AWS_API_KEY=AEAA...replace-me
ANTHROPIC_AWS_WORKSPACE_ID=wrkspc_01ABCDEFGHIJKLMN

# Optional — region for the CPaws endpoint. Falls back to AWS_REGION.
# CPaws workspaces are provisioned per region; if your workspace lives
# in us-east-2, set this even when AWS_REGION points elsewhere.
CPAWS_REGION=us-east-2
